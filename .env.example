# Career Co-Pilot Pro - Environment variables
# Copy to .env and fill in your values

# Required for Streamlit app (job search, ATS, tailoring)
OPENAI_API_KEY=sk-...
APIFY_API_TOKEN=apify_api_...

# Optional: candidate name for resume filename
CANDIDATE_NAME=Your Name

# For LinkedIn auto-apply (scripts/apply_linkedin_jobs.py, Job Apply MCP)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password
# Optional: linkedin-mcp-server HTTP transport (REST ``POST /api/ats/search-jobs`` + MCP ``search_jobs``)
# LINKEDIN_MCP_URL=http://127.0.0.1:8000/mcp

# Optional: Streamlit "ATS / API" tab — default FastAPI base (alias: CAREER_API_BASE_URL)
# STREAMLIT_CAREER_API_BASE=http://127.0.0.1:8000
# CAREER_API_BASE_URL=http://127.0.0.1:8000
# Optional: default JWT for Streamlit tab (or use CAREER_API_JWT); sent as Authorization: Bearer …
# STREAMLIT_CAREER_API_BEARER=eyJ...
# CAREER_API_JWT=eyJ...

# Optional: resume path (else uses Master_Resumes/*.pdf)
# RESUME_PATH=path/to/your/resume.pdf
# Default PDF when runner/MCP copies a master resume (deterministic; see services/resume_naming.py)
# MASTER_RESUME_PDF=Master_Resumes/my_master.pdf
# DEFAULT_RESUME_PDF=  # alias for MASTER_RESUME_PDF

# Optional: candidate profile path
# CANDIDATE_PROFILE_PATH=config/candidate_profile.json
# Optional: skip jobs whose location does not match profile application_locations (substring / remote_ok)
# POLICY_ENFORCE_JOB_LOCATION=1

# Docker: copy to `.env` for `docker compose` variable substitution (OPENAI_API_KEY, API_KEY, …).
# See docs/DEPLOY.md#docker and docker-compose.yml.

# Phase 3.5 — environment & secrets
# APP_ENV=development              # production | prod → stricter validation (fatal without auth + TRACKER_USE_DB=1)
# STRICT_STARTUP=1               # Force fatal checks in any APP_ENV; STRICT_STARTUP=0 disables exit in prod
# AWS_SECRETS_MANAGER_SECRET_ID= # Optional: JSON secret merged into env (unset keys only); needs boto3 + IAM
# AWS_SECRETS_MANAGER_REGION=    # Optional boto3 region for Secrets Manager

# API / Phase 3
# API_V1_DUPLICATE_ROUTES=0      # If set, do not mount the same routes under /api/v1 (only /api remains)
# API_CORS_ORIGINS=              # Comma-separated allowed origins for browser clients, e.g. http://localhost:8501,https://app.example.com
# API_CORS_ORIGINS=*             # Allow any origin (dev only; no credentials; fatal in APP_ENV=production unless API_CORS_SKIP_WILDCARD_PROD_CHECK=1)
# API_CORS_SKIP_WILDCARD_PROD_CHECK=1  # Escape hatch if you intentionally use CORS * in production (not recommended)
# API_RATE_LIMIT_ENABLED=1       # Per-IP sliding window (in-process; use edge limits for multi-replica)
# API_RATE_LIMIT_PER_MINUTE=120  # Max requests per client per window (default window 60s)
# API_RATE_LIMIT_WINDOW_SECONDS=60
# API_RATE_LIMIT_TRUST_X_FORWARDED_FOR=1  # Only behind a proxy that sets/sanitizes X-Forwarded-For
# API_RATE_LIMIT_LIVE_FORM_PROBE_PER_MINUTE=10  # Optional: tighter cap for POST /api/ats/analyze-form/live only (own bucket; works even if global limit is off). 0 = unset behavior (no dedicated cap)
# API_RATE_LIMIT_LIVE_FORM_PROBE_WINDOW_SECONDS=60  # Window for the live-probe bucket (defaults to API_RATE_LIMIT_WINDOW_SECONDS or 60)
# API_RATE_LIMIT_ATS_SEARCH_JOBS_PER_MINUTE=20  # Optional: cap POST /api/ats/search-jobs (LinkedIn MCP bridge); own bucket; works if global limit is off
# API_RATE_LIMIT_ATS_SEARCH_JOBS_WINDOW_SECONDS=60
# API_RATE_LIMIT_LINKEDIN_BROWSER_PER_MINUTE=5   # Optional: cap confirm-easy-apply + apply-to-jobs (+ dry-run); shared bucket; works if global limit is off
# API_RATE_LIMIT_LINKEDIN_BROWSER_WINDOW_SECONDS=60
# API_RATE_LIMIT_SKIP_STARTUP_WARN=1     # In APP_ENV=production: silence warning when API_RATE_LIMIT_ENABLED is off (edge limits only)
# ATS_ALLOW_LIVE_FORM_PROBE=1           # Allow read-only headless DOM probe (API + MCP analyze_form_live); requires Playwright Chromium
# ATS_ALLOW_LINKEDIN_BROWSER=1          # Allow confirm-easy-apply, apply-to-jobs, apply-to-jobs/dry-run on the API; MCP tools ignore this gate
# ATS_REQUIRE_OPERATOR_SUBMIT_APPROVAL=1  # Live apply-to-jobs (not dry_run, not shadow_mode) requires JSON operator_submit_approved=true; audit log when approved
# TRUTH_APPLY_HARD_GATE=1                 # Block live LinkedIn apply when profile is not auto-apply ready (dry_run / shadow_mode exempt); see services/truth_apply_gate.py
# API_KEY=secret-key-for-api-auth  # When set, X-API-Key header required (unless JWT used)
# Phase 4.1.3 — separate key for workers / automation (checked before JWT and X-API-Key when header is sent)
# M2M_API_KEY=...                   # If set, clients may send M2M_API_KEY_HEADER (default X-M2M-API-Key)
# M2M_API_KEY_HEADER=X-M2M-API-Key
# M2M_USER_ID=m2m-service
# M2M_SERVICE_ROLES=              # Comma-separated; optional M2M_API_KEY_IS_ADMIN=1
# JWT_SECRET=...                    # HS256 shared secret; Authorization: Bearer <jwt>
# JWT_JWKS_URL=https://...          # OIDC / JWKS (RS256, ES256, …); optional with JWT_ISSUER discovery
# JWT_ISSUER=https://your-idp/      # If set without JWT_JWKS_URL, fetches jwks_uri from OIDC discovery
# JWT_AUDIENCE=your-api-audience    # Recommended in production when using JWKS / issuer
# JWT_JWKS_ALGORITHMS=RS256,ES256   # Optional comma list (default RS256,RS384,RS512,ES256)
# JWT_ALGORITHM=HS256               # Fallback when only JWT_SECRET (non-HS256 header)
# JWT_ADMIN_ROLES=admin,superuser # Token roles (claim `role`, `roles`, or realm_access.roles) matching these get admin
# Phase 4.1.2 — optional workspace: JWT claims `workspace_id` or `org_id`, and/or HTTP header `X-Workspace-Id` (overrides claim)
# API_KEY_IS_ADMIN=1              # X-API-Key user treated as admin (for ops)
# DEMO_USER_IS_ADMIN=1            # Local only: demo-user is admin (avoid in shared envs)
# CELERY_ADMIN_INSPECT=0          # API: disable GET /api/admin/celery/inspect (returns 403)
# CELERY_INSPECT_TIMEOUT=2.0      # Default broker RPC timeout for admin Celery inspect (seconds)

# Postgres tracker pool (when using postgresql://)
# TRACKER_PG_POOL=1               # 0 = new connection per request (serverless / debug)
# TRACKER_PG_POOL_MIN=1
# TRACKER_PG_POOL_MAX=10

# Tracker (SQLite / Postgres / CSV)
# TRACKER_USE_DB=1                 # Use DB instead of CSV
# TRACKER_DB_PATH=job_applications.db  # SQLite file when no Postgres URL
# DATABASE_URL=sqlite:///path/to/job_applications.db
# TRACKER_DATABASE_URL=postgresql://user:pass@host:5432/dbname  # optional override (pip install .[postgres])
# DATABASE_URL=postgresql://...     # also used for tracker if TRACKER_DATABASE_URL unset
# TRACKER_DEFAULT_USER_ID=streamlit-local  # Stored on rows from Streamlit (API uses JWT/API key user id)

# Phase 4.2 — idempotent POST /api/jobs (multi-replica safe with DB)
# IDEMPOTENCY_USE_DB=1          # Store keys in tracker DB (not data/idempotency/). Postgres: also TRACKER_USE_DB=1
# IDEMPOTENCY_DIR=              # File store path when IDEMPOTENCY_USE_DB unset (default: data/idempotency)
# IDEMPOTENCY_TTL_HOURS=24

# Phase 4.2.2 — task snapshots (GET /api/jobs/{id}?include_task_state=true)
# TASK_STATE_BACKEND=file          # file (default) | db | s3
# TASK_STATE_DIR=                  # Default: data/task_state/
# TASK_STATE_MAX_BYTES=800000
# TASK_STATE_S3_BUCKET=            # Optional; defaults to ARTIFACTS_S3_BUCKET when backend=s3
# TASK_STATE_S3_PREFIX=task_state

# Phase 3.6 — observability
# CELERY_METRICS_REDIS=1        # Workers: increment Redis hash ccp:metrics:celery; API: read for admin summary / Prometheus bridge (auto)
# APPLY_RUNNER_METRICS_REDIS=1  # Phase 4.5.1: LinkedIn apply script / browser automation → hash ccp:metrics:apply_runner (see docs/APPLY_RECOVERY_PLAYBOOKS.md)
# PROMETHEUS_CELERY_REDIS=1     # API: mirror Redis Celery counters on GET /metrics (optional; use 0 to disable bridge only)
# REDIS_METRICS_URL=redis://localhost:6379/0   # Optional; else REDIS_BROKER
# PROMETHEUS_METRICS=1          # API: GET /metrics (pip install .[metrics])
# LOG_JSON=1                    # JSON logs to stdout
# AUDIT_LOG_PATH=application_audit.jsonl
# Phase 4.3 — metrics webhook alert (cron scripts/metrics_webhook_alert.py; needs CELERY_METRICS_REDIS=1 here or on workers)
# METRICS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# METRICS_ALERT_ERROR_TOTAL_MIN=5       # POST if tasks_error_total >= this (set any *_MIN to enable checks)
# METRICS_ALERT_ERROR_PERMANENT_MIN=1
# METRICS_ALERT_ERROR_TRANSIENT_MIN=
# METRICS_ALERT_REJECTED_TOTAL_MIN=
# METRICS_ALERT_COOLDOWN_SECONDS=3600   # Min seconds between successful POSTs (state: data/.metrics_alert_last_sent)
# METRICS_ALERT_WEBHOOK_TIMEOUT=15

# Phase 12 — follow-up (stored on tracker rows; see docs/FOLLOW_UPS.md)
# Use API: PATCH /api/applications/{id}/follow-up with follow_up_at (ISO), follow_up_status, follow_up_note
# Optional SMTP for scripts/email_follow_up_digest.py (cron)
# FOLLOW_UP_SMTP_HOST=smtp.gmail.com
# FOLLOW_UP_SMTP_PORT=587
# FOLLOW_UP_SMTP_USER=you@gmail.com
# FOLLOW_UP_SMTP_PASSWORD=app-password
# FOLLOW_UP_EMAIL_TO=you@gmail.com
# FOLLOW_UP_EMAIL_FROM=you@gmail.com
# FOLLOW_UP_EMAIL_SUBJECT=Job follow-up reminders
# FOLLOW_UP_SMTP_USE_TLS=1
# Webhook (Slack incoming URL, Discord webhook, or custom) — see docs/FOLLOW_UPS.md
# FOLLOW_UP_WEBHOOK_URL=https://hooks.slack.com/services/...
# FOLLOW_UP_WEBHOOK_STYLE=slack
# FOLLOW_UP_WEBHOOK_BEARER=
# FOLLOW_UP_WEBHOOK_HEADERS_JSON=
# FOLLOW_UP_WEBHOOK_TIMEOUT=30
# Telegram Bot API — scripts/telegram_follow_up_digest.py (create bot via @BotFather, get chat_id from updates)
# FOLLOW_UP_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# FOLLOW_UP_TELEGRAM_CHAT_ID=your_numeric_chat_id
# FOLLOW_UP_TELEGRAM_TIMEOUT=30
# Or use scripts/notify_follow_up_digest.py to fire all configured channels in one run
